generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         String   @default("EDITOR") // SUPER_ADMIN or EDITOR
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ServicePage {
  id               String             @id @default(cuid())
  title            String
  slug             String             @unique
  description      String?
  excerpt          String?
  homeImage        String?
  homeScene        String?
  scene            String
  icon             String             @default("◈")
  order            Int                @default(0)
  isActive         Boolean            @default(true)
  translations     Json?              @default("{}")
  categories       Category[]
  testimonialMedia TestimonialMedia[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Category {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  servicePageId String
  servicePage   ServicePage @relation(fields: [servicePageId], references: [id], onDelete: Cascade)
  order         Int         @default(0)
  isActive      Boolean     @default(true)
  translations  Json?       @default("{}")
  projects      Project[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Project {
  id           String         @id @default(cuid())
  title        String
  description  String?
  likesCount   Int            @default(0)
  fakeLikes    Int            @default(0)
  viewsCount   Int            @default(0)
  fakeViews    Int            @default(0)
  sharesCount  Int            @default(0)
  fakeShares   Int            @default(0)
  categoryId   String
  category     Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  order        Int            @default(0)
  isActive     Boolean        @default(true)
  translations Json?          @default("{}")
  media        ProjectMedia[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model ProjectMedia {
  id        String   @id @default(cuid())
  url       String
  type      String   // e.g. 'IMAGE' or 'VIDEO'
  projectId String
  order     Int      @default(0)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model TestimonialMedia {
  id            String      @id @default(cuid())
  url           String
  type          String
  servicePageId String
  order         Int         @default(0)
  servicePage   ServicePage @relation(fields: [servicePageId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
}

model TestimonialComment {
  id         String   @id @default(cuid())
  authorName String
  content    String
  ipAddress  String?
  isHidden   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ProminentClient {
  id        String   @id @default(cuid())
  name      String?
  logoUrl   String?
  link      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  eventType  String   // 'PAGE_VIEW' | 'PROJECT_VIEW' | 'CATEGORY_VIEW' | 'WHATSAPP_CLICK' | 'EMAIL_CLICK' | 'PROJECT_LIKE' | 'PROJECT_SHARE'
  targetId   String?  // Slug or ID of the target page/project/category
  targetName String?  // Display name of the target item
  createdAt  DateTime @default(now())

  @@index([eventType])
}
